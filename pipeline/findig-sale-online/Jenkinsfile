// ============================================================
// Jenkinsfile — findig-sale-online (Windows Server)
//
// โครงสร้าง:
//   findig-sale-online/         ← React frontend (build บน Jenkins agent)
//   findig-sale-online/server/  ← Express proxy server (deploy ไป production)
//     server.js                 ← serve build/ + proxy ไป backend
//     build/                    ← React build output (copy มาจาก Jenkins)
//
// Prerequisites (ตั้งค่าใน Jenkins ก่อน):
//   Credentials:
//     - ID: findig-sale-online-env-prod     (Secret File)
//         ตัวอย่างเนื้อหา .env.prod:
//           REACT_APP_API_USER=admin
//           REACT_APP_API_KEY=supersecret
//           REACT_APP_SERVICE_HOST=http://YOUR_SERVER_IP:9090/api
//           WEB_PORT=3000
//           SERVICE_HOST=http://127.0.0.1:9090
//
//     - ID: deploy-server-ssh   (SSH Username with Private Key)
//
//   Plugins:
//     - SSH Agent Plugin
//     - Credentials Binding Plugin
//     - NodeJS Plugin (แนะนำให้ configure Node version ใน Global Tool Config)
//
//   Jenkins Agent (Windows):
//     - Windows Server 2019 Build 17063+ หรือ Windows 10 1803+
//       (มี tar.exe built-in — ถ้าเก่ากว่าให้ติดตั้ง Git for Windows)
//     - OpenSSH Client
//     - Node.js + npm
//
//   Windows Deploy Server:
//     - OpenSSH Server
//     - PowerShell 5.1+ หรือ PowerShell Core 7+
//     - Node.js + npm + PM2 (npm install -g pm2)
//     - ตั้ง PowerShell ExecutionPolicy:
//       Set-ExecutionPolicy RemoteSigned -Scope LocalMachine
// ============================================================

pipeline {
    agent { label 'windows' }  // ปรับเป็น label ของ Windows Jenkins agent จริง

    environment {
        APP_NAME    = 'findig-sale-online'
        // ---------- ปรับค่าให้ตรงกับ server จริง ----------
        DEPLOY_HOST = '192.168.1.100'
        DEPLOY_USER = 'Administrator'               // Windows Server user
        DEPLOY_DIR  = 'C:/apps/findig-sale-online'  // forward slash ใช้ได้ทั้ง SCP และ PowerShell
        // ---------------------------------------------------
        SSH_CRED_ID = 'deploy-server-ssh'
        ENV_CRED_ID = 'findig-sale-online-env-prod'
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        // ----------------------------------------------------------
        stage('Checkout') {
        // ----------------------------------------------------------
            steps {
                checkout scm
            }
        }

        // ----------------------------------------------------------
        stage('Load Env') {
        // ----------------------------------------------------------
        // ดึง .env.prod มาใช้สำหรับ React build (REACT_APP_*)
        // และ server runtime (WEB_PORT, SERVICE_HOST) ในไฟล์เดียวกัน
            steps {
                withCredentials([file(credentialsId: ENV_CRED_ID, variable: 'ENV_PROD_FILE')]) {
                    powershell '''
                        Copy-Item "$env:ENV_PROD_FILE" -Destination "findig-sale-online\\.env.prod"        -Force
                        Copy-Item "$env:ENV_PROD_FILE" -Destination "findig-sale-online\\.env.production"  -Force
                        Copy-Item "$env:ENV_PROD_FILE" -Destination "findig-sale-online\\server\\.env.prod" -Force
                    '''
                }
            }
        }

        // ----------------------------------------------------------
        stage('Install & Build React') {
        // ----------------------------------------------------------
        // Build บน Jenkins agent — ใช้ build:windows แทน build
        // เพราะ build script ใช้ "rm -rf" ซึ่งไม่รองรับบน Windows
            steps {
                dir('findig-sale-online') {
                    bat 'npm ci'
                    bat 'npm run build:windows'
                }
            }
        }

        // ----------------------------------------------------------
        stage('Package') {
        // ----------------------------------------------------------
        // Archive แยกเป็น 2 ชุด:
        //   deploy-frontend.tar.gz → React build output (findig-sale-online/build/)
        //   deploy-server.tar.gz   → Express server source (findig-sale-online/server/)
            steps {
                powershell '''
                    Remove-Item -Force deploy-frontend.tar.gz -ErrorAction SilentlyContinue
                    Remove-Item -Force deploy-server.tar.gz   -ErrorAction SilentlyContinue

                    tar -czf deploy-frontend.tar.gz findig-sale-online/build

                    tar -czf deploy-server.tar.gz `
                        --exclude=findig-sale-online/server/node_modules `
                        --exclude=findig-sale-online/server/.env.prod `
                        --exclude=findig-sale-online/server/build `
                        --exclude=findig-sale-online/server/.DS_Store `
                        findig-sale-online/server
                '''
            }
        }

        // ----------------------------------------------------------
        stage('Deploy') {
        // ----------------------------------------------------------
        // 1. เขียน PowerShell deploy script ลงไฟล์ชั่วคราว
        // 2. โอน archives + env + script ไปยัง Windows Server ผ่าน SCP
        // 3. รัน script บน server ผ่าน SSH
        //
        // โครงสร้างบน Deploy Server:
        //   $DEPLOY_DIR/server/build/   ← React static files
        //   $DEPLOY_DIR/server/         ← Express server + package.json
        //   $DEPLOY_DIR/server/.env     ← runtime env (อ่านโดย dotenv)
            steps {
                script {
                    def deployDir = env.DEPLOY_DIR
                    def appName   = env.APP_NAME

                    writeFile file: 'deploy-frontend-remote.ps1', text: """
Set-StrictMode -Version Latest
\$ErrorActionPreference = 'Stop'

\$deployDir = '${deployDir}'
\$appName   = '${appName}'

Write-Host '[INFO] Creating directory structure...'
New-Item -ItemType Directory -Force -Path "\$deployDir/server/build" | Out-Null

Write-Host '[INFO] Extracting React build output...'
tar -xzf 'C:/Windows/Temp/deploy-frontend.tar.gz' -C "\$deployDir/server/build" --strip-components=2

Write-Host '[INFO] Extracting Express server source...'
tar -xzf 'C:/Windows/Temp/deploy-server.tar.gz' -C \$deployDir --strip-components=1

Set-Location "\$deployDir/server"

Write-Host '[INFO] Installing server dependencies...'
npm ci --omit=dev

Write-Host '[INFO] Managing PM2 process...'
try {
    \$processes = pm2 jlist 2>\$null | ConvertFrom-Json -ErrorAction SilentlyContinue
    \$isRunning = \$null -ne (\$processes | Where-Object { \$_.name -eq \$appName })
} catch {
    \$isRunning = \$false
}

if (\$isRunning) {
    Write-Host '[INFO] Reloading existing PM2 process...'
    pm2 reload \$appName --update-env
} else {
    Write-Host '[INFO] Starting new PM2 process...'
    pm2 start server.js --name \$appName
}
pm2 save

Write-Host '[INFO] Cleaning up temp files on server...'
Remove-Item -Force 'C:/Windows/Temp/deploy-frontend.tar.gz'     -ErrorAction SilentlyContinue
Remove-Item -Force 'C:/Windows/Temp/deploy-server.tar.gz'       -ErrorAction SilentlyContinue
Remove-Item -Force 'C:/Windows/Temp/deploy-frontend-remote.ps1' -ErrorAction SilentlyContinue

Write-Host '[SUCCESS] Deployment completed.'
"""
                }

                sshagent(credentials: [SSH_CRED_ID]) {
                    // โอนไฟล์ไปยัง Windows Server
                    powershell "scp -o StrictHostKeyChecking=no deploy-frontend.tar.gz          ${DEPLOY_USER}@${DEPLOY_HOST}:C:/Windows/Temp/deploy-frontend.tar.gz"
                    powershell "scp -o StrictHostKeyChecking=no deploy-server.tar.gz            ${DEPLOY_USER}@${DEPLOY_HOST}:C:/Windows/Temp/deploy-server.tar.gz"
                    powershell "scp -o StrictHostKeyChecking=no findig-sale-online/server/.env.prod ${DEPLOY_USER}@${DEPLOY_HOST}:${DEPLOY_DIR}/server/.env"
                    powershell "scp -o StrictHostKeyChecking=no deploy-frontend-remote.ps1      ${DEPLOY_USER}@${DEPLOY_HOST}:C:/Windows/Temp/deploy-frontend-remote.ps1"

                    // รัน deploy script บน Windows Server
                    powershell "ssh -o StrictHostKeyChecking=no ${DEPLOY_USER}@${DEPLOY_HOST} powershell -ExecutionPolicy Bypass -File C:/Windows/Temp/deploy-frontend-remote.ps1"
                }
            }
        }
    }

    post {
        success {
            echo "[SUCCESS] ${APP_NAME} deployed successfully — build #${BUILD_NUMBER}"
        }
        failure {
            echo "[FAILED] ${APP_NAME} deployment failed — build #${BUILD_NUMBER}"
        }
        cleanup {
            // ลบไฟล์ชั่วคราวออกจาก workspace เสมอ ไม่ว่า pipeline จะสำเร็จหรือไม่
            powershell '''
                Remove-Item -Force "findig-sale-online\\.env.prod"          -ErrorAction SilentlyContinue
                Remove-Item -Force "findig-sale-online\\.env.production"    -ErrorAction SilentlyContinue
                Remove-Item -Force "findig-sale-online\\server\\.env.prod"  -ErrorAction SilentlyContinue
                Remove-Item -Force "deploy-frontend.tar.gz"                 -ErrorAction SilentlyContinue
                Remove-Item -Force "deploy-server.tar.gz"                   -ErrorAction SilentlyContinue
                Remove-Item -Force "deploy-frontend-remote.ps1"             -ErrorAction SilentlyContinue
            '''
        }
    }
}
