// ============================================================
// Jenkinsfile — findig-backend-service (Windows Server)
//
// Prerequisites (ตั้งค่าใน Jenkins ก่อน):
//   Credentials:
//     - ID: findig-backend-env-prod   (Secret File)  → ไฟล์ .env.prod
//     - ID: deploy-server-ssh         (SSH Username with Private Key)
//
//   Plugins:
//     - SSH Agent Plugin
//     - Credentials Binding Plugin
//
//   Jenkins Agent (Windows):
//     - Windows Server 2019 Build 17063+ หรือ Windows 10 1803+
//       (มี tar.exe built-in — ถ้าเก่ากว่าให้ติดตั้ง Git for Windows)
//     - OpenSSH Client (Settings → Apps → Optional Features → OpenSSH Client)
//     - Node.js + npm
//
//   Windows Deploy Server:
//     - OpenSSH Server (Settings → Apps → Optional Features → OpenSSH Server)
//     - PowerShell 5.1+ หรือ PowerShell Core 7+
//     - Node.js + npm + PM2 (npm install -g pm2)
//     - ตั้ง PowerShell ExecutionPolicy:
//       Set-ExecutionPolicy RemoteSigned -Scope LocalMachine
// ============================================================

pipeline {
    agent { label 'windows' }  // ปรับเป็น label ของ Windows Jenkins agent จริง

    environment {
        APP_NAME    = 'findig-backend-service'
        // ---------- ปรับค่าให้ตรงกับ server จริง ----------
        DEPLOY_HOST = '192.168.1.100'
        DEPLOY_USER = 'Administrator'               // Windows Server user
        DEPLOY_DIR  = 'C:/apps/findig-backend-service'  // forward slash ใช้ได้ทั้ง SCP และ PowerShell
        // ---------------------------------------------------
        SSH_CRED_ID = 'deploy-server-ssh'
        ENV_CRED_ID = 'findig-backend-env-prod'
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        // ----------------------------------------------------------
        stage('Checkout') {
        // ----------------------------------------------------------
            steps {
                checkout scm
            }
        }

        // ----------------------------------------------------------
        stage('Load Env') {
        // ----------------------------------------------------------
        // ดึง .env.prod จาก Jenkins Credentials (Secret File)
        // ไฟล์นี้จะถูกลบออกจาก workspace ใน cleanup เสมอ
            steps {
                withCredentials([file(credentialsId: ENV_CRED_ID, variable: 'ENV_PROD_FILE')]) {
                    powershell 'Copy-Item "$env:ENV_PROD_FILE" -Destination "findig-backend-service\\.env.prod" -Force'
                }
            }
        }

        // ----------------------------------------------------------
        stage('Package') {
        // ----------------------------------------------------------
        // Archive source code ยกเว้น node_modules, .env*, logs
        // tar.exe built-in ใน Windows Server 2019 Build 17063+
            steps {
                powershell '''
                    Remove-Item -Force deploy-backend.tar.gz -ErrorAction SilentlyContinue
                    tar -czf deploy-backend.tar.gz `
                        --exclude=findig-backend-service/node_modules `
                        --exclude=findig-backend-service/.env.prod `
                        --exclude=findig-backend-service/logs `
                        --exclude=findig-backend-service/.DS_Store `
                        findig-backend-service
                '''
            }
        }

        // ----------------------------------------------------------
        stage('Deploy') {
        // ----------------------------------------------------------
        // 1. เขียน PowerShell deploy script ลงไฟล์ชั่วคราว
        // 2. โอน archive + env + script ไปยัง Windows Server ผ่าน SCP
        // 3. รัน script บน server ผ่าน SSH
        //
        // ใช้ script file แทน inline command เพื่อหลีกเลี่ยงปัญหา quoting
        // ใน nested SSH → PowerShell
            steps {
                script {
                    def deployDir = env.DEPLOY_DIR
                    def appName   = env.APP_NAME

                    writeFile file: 'deploy-backend-remote.ps1', text: """
Set-StrictMode -Version Latest
\$ErrorActionPreference = 'Stop'

\$deployDir = '${deployDir}'
\$appName   = '${appName}'

Write-Host '[INFO] Creating deploy directories...'
New-Item -ItemType Directory -Force -Path "\$deployDir/logs" | Out-Null

Write-Host '[INFO] Extracting source archive...'
tar -xzf 'C:/Windows/Temp/deploy-backend.tar.gz' -C \$deployDir --strip-components=1

Set-Location \$deployDir

Write-Host '[INFO] Installing production dependencies...'
npm ci --omit=dev

Write-Host '[INFO] Managing PM2 process...'
try {
    \$processes = pm2 jlist 2>\$null | ConvertFrom-Json -ErrorAction SilentlyContinue
    \$isRunning = \$null -ne (\$processes | Where-Object { \$_.name -eq \$appName })
} catch {
    \$isRunning = \$false
}

if (\$isRunning) {
    Write-Host '[INFO] Reloading existing PM2 process...'
    pm2 reload \$appName --update-env
} else {
    Write-Host '[INFO] Starting new PM2 process via ecosystem.config.js...'
    pm2 start ecosystem.config.js
}
pm2 save

Write-Host '[INFO] Cleaning up temp files on server...'
Remove-Item -Force 'C:/Windows/Temp/deploy-backend.tar.gz'      -ErrorAction SilentlyContinue
Remove-Item -Force 'C:/Windows/Temp/deploy-backend-remote.ps1'  -ErrorAction SilentlyContinue

Write-Host '[SUCCESS] Deployment completed.'
"""
                }

                sshagent(credentials: [SSH_CRED_ID]) {
                    // โอนไฟล์ไปยัง Windows Server
                    powershell "scp -o StrictHostKeyChecking=no deploy-backend.tar.gz         ${DEPLOY_USER}@${DEPLOY_HOST}:C:/Windows/Temp/deploy-backend.tar.gz"
                    powershell "scp -o StrictHostKeyChecking=no findig-backend-service/.env.prod ${DEPLOY_USER}@${DEPLOY_HOST}:${DEPLOY_DIR}/.env.prod"
                    powershell "scp -o StrictHostKeyChecking=no deploy-backend-remote.ps1      ${DEPLOY_USER}@${DEPLOY_HOST}:C:/Windows/Temp/deploy-backend-remote.ps1"

                    // รัน deploy script บน Windows Server
                    powershell "ssh -o StrictHostKeyChecking=no ${DEPLOY_USER}@${DEPLOY_HOST} powershell -ExecutionPolicy Bypass -File C:/Windows/Temp/deploy-backend-remote.ps1"
                }
            }
        }
    }

    post {
        success {
            echo "[SUCCESS] ${APP_NAME} deployed successfully — build #${BUILD_NUMBER}"
        }
        failure {
            echo "[FAILED] ${APP_NAME} deployment failed — build #${BUILD_NUMBER}"
        }
        cleanup {
            // ลบไฟล์ชั่วคราวออกจาก workspace เสมอ ไม่ว่า pipeline จะสำเร็จหรือไม่
            powershell '''
                Remove-Item -Force "findig-backend-service\\.env.prod" -ErrorAction SilentlyContinue
                Remove-Item -Force "deploy-backend.tar.gz"             -ErrorAction SilentlyContinue
                Remove-Item -Force "deploy-backend-remote.ps1"         -ErrorAction SilentlyContinue
            '''
        }
    }
}
